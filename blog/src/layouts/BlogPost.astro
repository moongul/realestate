---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			main {
				width: 100%;
				max-width: 1080px;
				margin: 0 auto;
				padding: 80px 24px;
			}
			article {
				background: var(--canvas);
				overflow: hidden;
			}
			.prose {
				color: var(--body);
				line-height: 1.7;
				font-size: 17px;
				word-break: keep-all;
				overflow-wrap: break-word;
				max-width: 800px;
				margin: 0 auto;
			}
			.title-section {
				text-align: center;
				margin-bottom: 64px;
				max-width: 900px;
				margin-left: auto;
				margin-right: auto;
			}
			.title-section h1 {
				font-size: 44px;
				font-weight: 700;
				color: var(--primary);
				line-height: 1.2;
				margin: 16px 0;
				font-family: 'Source Serif 4', serif;
			}
			.meta-row {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
				margin-bottom: 12px;
				font-size: 14px;
				font-weight: 600;
				color: var(--muted);
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}
			.category-divider { color: var(--hairline); }
			.category-name { color: var(--secondary); }

			/* Content Elements */
			.prose h2 {
				font-size: 28px;
				margin-top: 64px;
				margin-bottom: 24px;
				color: var(--primary);
				font-weight: 700;
				padding-bottom: 16px;
				border-bottom: 1px solid var(--outline-variant);
			}
			.prose h3 {
				font-size: 22px;
				margin-top: 40px;
				margin-bottom: 16px;
				color: var(--primary);
				font-weight: 700;
			}
			.prose p {
				margin-bottom: 28px;
			}
			/* Enhanced Table Styling */
			.prose table {
				width: 100%;
				border-collapse: separate;
				border-spacing: 0;
				margin: 40px 0;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-md);
				overflow: hidden;
				box-shadow: var(--shadow-sm);
			}
			.prose th {
				background: #f8f9fa;
				padding: 16px;
				border-bottom: 1px solid var(--outline-variant);
				text-align: left;
				font-weight: 700;
				font-size: 14px;
				color: var(--primary);
			}
			.prose td {
				padding: 16px;
				border-bottom: 1px solid var(--outline-variant);
				font-size: 15px;
				background: white;
			}
			.prose tr:last-child td {
				border-bottom: none;
			}
			/* Highlight Boxes / Callouts */
			.prose blockquote {
				border: 1px solid var(--outline-variant);
				border-left: 4px solid var(--secondary);
				padding: 32px;
				margin: 48px 0;
				background: white;
				border-radius: var(--rounded-md);
				font-style: normal;
				color: var(--body);
				box-shadow: var(--shadow-sm);
			}
			.prose blockquote strong {
				display: block;
				font-size: 18px;
				margin-bottom: 12px;
				color: var(--secondary);
				font-family: 'Source Serif 4', serif;
			}
			/* Horizontal Rule */
			.prose hr {
				border: 0;
				border-top: 1px solid var(--outline-variant);
				margin: 64px 0;
			}

			/* 2-Row Data Grid Layout */
			.data-card-grid-rows {
				display: flex;
				flex-direction: column;
				gap: 24px;
				margin: 48px 0;
			}
			.data-card {
				padding: 32px;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-lg);
				background: white;
				box-shadow: var(--shadow-sm);
				transition: transform 0.2s;
			}
			.data-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}
			.data-card .label {
				font-size: 12px;
				color: var(--muted);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-weight: 800;
				margin-bottom: 12px;
				display: block;
			}
			.data-card .value {
				font-size: 18px;
				font-weight: 500;
				color: var(--primary);
				line-height: 1.6;
			}
			
			@media (max-width: 720px) {
				.title-section h1 { font-size: 32px; }
				main { padding: 48px 16px; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title-section">
						<div class="meta-row">
							<div class="date">
								<FormattedDate date={pubDate} />
							</div>
							<span class="category-divider">/</span>
							<span class="category-name">
								{Astro.props.category === 'market' ? 'Daily Intelligence' : 'Industrial Report'}
							</span>
						</div>
						<h1>{title}</h1>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
