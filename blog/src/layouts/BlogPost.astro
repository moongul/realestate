---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			main {
				width: 100%;
				max-width: 1080px;
				margin: 0 auto;
				padding: 80px 24px;
			}
			article {
				background: var(--canvas);
				overflow: hidden;
			}
			.prose {
				color: var(--body);
				line-height: 1.7;
				font-size: 17px;
				word-break: keep-all;
				overflow-wrap: break-word;
				max-width: 800px;
				margin: 0 auto;
			}
			.title-section {
				text-align: center;
				margin-bottom: 64px;
				max-width: 900px;
				margin-left: auto;
				margin-right: auto;
			}
			.title-section h1 {
				font-size: 44px;
				font-weight: 700;
				color: var(--primary);
				line-height: 1.2;
				margin: 16px 0;
			}
			.meta-row {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
				margin-bottom: 12px;
				font-size: 14px;
				font-weight: 600;
				color: var(--muted);
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}
			.category-divider { color: var(--hairline); }
			.category-name { color: var(--secondary); }

			/* Content Elements */
			.prose h2 {
				font-size: 28px;
				margin-top: 64px;
				margin-bottom: 24px;
				color: var(--primary);
				font-weight: 700;
				padding-bottom: 16px;
				border-bottom: 1px solid var(--outline-variant);
			}
			.prose h3 {
				font-size: 22px;
				margin-top: 40px;
				margin-bottom: 16px;
				color: var(--primary);
				font-weight: 700;
			}
			.prose p {
				margin-bottom: 28px;
			}
			/* Enhanced Table Styling */
			.prose table {
				width: 100%;
				border-collapse: separate;
				border-spacing: 0;
				margin: 40px 0;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-md);
				overflow: hidden;
				box-shadow: var(--shadow-sm);
			}
			.prose th {
				background: #f8f9fa;
				padding: 16px;
				border-bottom: 1px solid var(--outline-variant);
				text-align: left;
				font-weight: 700;
				font-size: 14px;
				color: var(--primary);
			}
			.prose td {
				padding: 16px;
				border-bottom: 1px solid var(--outline-variant);
				font-size: 15px;
				background: white;
			}
			.prose tr:last-child td {
				border-bottom: none;
			}
			/* Highlight Boxes / Callouts */
			.prose blockquote {
				border: 1px solid var(--outline-variant);
				border-left: 4px solid var(--secondary);
				padding: 32px;
				margin: 48px 0;
				background: white;
				border-radius: var(--rounded-md);
				font-style: normal;
				color: var(--body);
				box-shadow: var(--shadow-sm);
			}
			.prose blockquote strong {
				display: block;
				font-size: 18px;
				margin-bottom: 12px;
				color: var(--secondary);
			}
			/* Horizontal Rule */
			.prose hr {
				border: 0;
				border-top: 1px solid var(--outline-variant);
				margin: 64px 0;
			}

			/* 2-Row Data Grid Layout */
			.data-card-grid-rows {
				display: flex;
				flex-direction: column;
				gap: 24px;
				margin: 48px 0;
			}
			.data-card {
				padding: 32px;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-lg);
				background: white;
				box-shadow: var(--shadow-sm);
				transition: transform 0.2s;
			}
			.data-card:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}
			.data-card .label {
				font-size: 12px;
				color: var(--muted);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-weight: 800;
				margin-bottom: 12px;
				display: block;
			}
			.data-card .value {
				font-size: 18px;
				font-weight: 500;
				color: var(--primary);
				line-height: 1.6;
			}

			/* District Link Style */
			.district-link {
				color: var(--secondary);
				font-weight: 700;
				cursor: pointer;
				text-decoration: underline;
				text-underline-offset: 4px;
				background: none;
				border: none;
				padding: 0;
				font-family: inherit;
				font-size: inherit;
			}
			.district-link:hover {
				color: var(--primary);
			}

			/* Modal Styles */
			#district-modal {
				border: none;
				border-radius: var(--rounded-lg);
				padding: 0;
				max-width: 600px;
				width: 90%;
				box-shadow: 0 20px 50px rgba(0,0,0,0.3);
			}
			#district-modal::backdrop {
				background: rgba(4, 22, 39, 0.4);
				backdrop-filter: blur(4px);
			}
			.modal-container {
				padding: 40px;
				background: white;
			}
			.modal-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 32px;
			}
			.modal-header h2 {
				font-size: 28px;
				margin: 0;
				border: none;
				padding: 0;
			}
			.close-btn {
				background: var(--surface-variant);
				border: none;
				width: 32px;
				height: 32px;
				border-radius: 50%;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.modal-stats {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 20px;
				margin-bottom: 32px;
			}
			.m-stat-item {
				padding: 16px;
				background: var(--canvas);
				border-radius: var(--rounded-md);
			}
			.m-stat-label {
				font-size: 11px;
				text-transform: uppercase;
				color: var(--muted);
				font-weight: 800;
				margin-bottom: 4px;
				display: block;
			}
			.m-stat-value {
				font-size: 18px;
				font-weight: 700;
				color: var(--primary);
			}
			.modal-chart-container {
				height: 200px;
				background: #fdfdfd;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-md);
				padding: 20px;
				position: relative;
			}
			.modal-chart-label {
				position: absolute;
				top: 10px;
				right: 20px;
				font-size: 10px;
				color: var(--muted);
				font-weight: 700;
			}
			
			@media (max-width: 720px) {
				.title-section h1 { font-size: 32px; }
				main { padding: 48px 16px; }
				.modal-container { padding: 24px; }
				.modal-stats { grid-template-columns: 1fr; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title-section">
						<div class="meta-row">
							<div class="date">
								<FormattedDate date={pubDate} />
							</div>
							<span class="category-divider">/</span>
							<span class="category-name">
								{Astro.props.category === 'market' ? '시세 브리핑' : '분석 리포트'}
							</span>
							<span class="category-divider">/</span>
							<span class="view-count" title="페이지 조회수">
								<span class="material-symbols-outlined" style="font-size: 14px; margin-right: 2px;">&#xe8f4;</span>
								<span id="page-views">...</span>
							</span>
						</div>
						<h1>{title}</h1>
					</div>
					<slot />
				</div>
			</article>
		</main>

		<!-- District Detail Modal -->
		<dialog id="district-modal">
			<div class="modal-container">
				<div class="modal-header">
					<div>
						<h2 id="modal-title">자치구 상세 분석</h2>
						<p id="modal-subtitle" style="color: var(--muted); font-size: 14px; margin-top: 4px;">누적 데이터 기반 시세 추이</p>
					</div>
					<button class="close-btn material-symbols-outlined" id="close-modal">&#xe5cd;</button>
				</div>
				
				<div class="modal-stats">
					<div class="m-stat-item">
						<span class="m-stat-label">평균 매매가</span>
						<span class="m-stat-value" id="stat-avg-price">-</span>
					</div>
					<div class="m-stat-item">
						<span class="m-stat-label">평균 전세가</span>
						<span class="m-stat-value" id="stat-avg-jeonse">-</span>
					</div>
					<div class="m-stat-item">
						<span class="m-stat-label">평균 월세</span>
						<span class="m-stat-value" id="stat-avg-wolse">-</span>
					</div>
					<div class="m-stat-item">
						<span class="m-stat-label">누적 거래량</span>
						<span class="m-stat-value" id="stat-total-trades">-</span>
					</div>
					<div class="m-stat-item">
						<span class="m-stat-label">최근 변동률</span>
						<span class="m-stat-value" id="stat-diff-rate">-</span>
					</div>
				</div>

				<div class="modal-chart-container">
					<div class="modal-chart-label">전체 기간 시세 변동 추이</div>
					<svg id="modal-chart-svg" viewBox="0 0 800 200" style="width: 100%; height: 100%;" preserveAspectRatio="none">
						<path id="modal-chart-path" d="" fill="none" stroke="var(--secondary)" stroke-width="3" stroke-linejoin="round" stroke-linecap="round"></path>
						<path id="modal-chart-area" d="" fill="var(--secondary)" opacity="0.05"></path>
					</svg>
				</div>
			</div>
		</dialog>

		<script is:inline>
			let districtHistory = null;
			const modal = document.getElementById('district-modal');
			const closeModal = document.getElementById('close-modal');
			
			const DISTRICTS = ["강남구", "강동구", "강북구", "강서구", "관악구", "광진구", "구로구", "금천구", "노원구", "도봉구", "동대문구", "동작구", "마포구", "서대문구", "서초구", "성동구", "성북구", "송파구", "양천구", "영등포구", "용산구", "은평구", "종로구", "중구", "중랑구"];

			async function initDistricts() {
				// 1. 데이터 로드
				if (!districtHistory) {
					try {
						const res = await fetch('/data/district_history.json');
						districtHistory = await res.json();
					} catch (e) {
						console.error('Failed to load district history:', e);
						return;
					}
				}

				// 2. 표 안의 구 이름들을 링크로 변환
				const cells = document.querySelectorAll('.prose td');
				cells.forEach(cell => {
					const text = cell.innerText.trim();
					// 정확히 구 이름과 일치하거나 구 이름을 포함하는 경우 (예: **강남구**)
					const matchedDistrict = DISTRICTS.find(d => text.includes(d));
					if (matchedDistrict) {
						const originalContent = cell.innerHTML;
						const linkHTML = originalContent.replace(matchedDistrict, `<button class="district-link" data-district="${matchedDistrict}">${matchedDistrict}</button>`);
						cell.innerHTML = linkHTML;
					}
				});

				// 3. 클릭 이벤트 리스너 등록
				document.querySelectorAll('.district-link').forEach(link => {
					link.addEventListener('click', (e) => {
						const name = e.target.getAttribute('data-district');
						openDistrictModal(name);
					});
				});
			}

			function openDistrictModal(name) {
				const data = districtHistory[name];
				if (!data || data.length === 0) return;

				// 통계 업데이트
				const latest = data[data.length - 1];
				document.getElementById('modal-title').innerText = `${name} 상세 분석`;
				document.getElementById('stat-avg-price').innerText = `${(latest.avg_price / 10000).toFixed(2)}억`;
				document.getElementById('stat-avg-jeonse').innerText = latest.avg_jeonse ? `${(latest.avg_jeonse / 10000).toFixed(2)}억` : '데이터 없음';
				document.getElementById('stat-avg-wolse').innerText = latest.avg_wolse ? `${Math.round(latest.avg_wolse)}만` : '데이터 없음';
				
				const totalTrades = data.reduce((sum, item) => sum + item.trade_count, 0);
				document.getElementById('stat-total-trades').innerText = `${totalTrades}건`;
				
				const diff = latest.prev_diff_rate;
				document.getElementById('stat-diff-rate').innerText = `${diff > 0 ? '+' : ''}${diff.toFixed(2)}%`;
				document.getElementById('stat-diff-rate').style.color = diff > 0 ? 'var(--error)' : (diff < 0 ? 'var(--secondary)' : 'var(--muted)');

				// 차트 그리기
				drawModalChart(data);

				modal.showModal();
			}

			function drawModalChart(data) {
				const prices = data.map(d => d.avg_price);
				const max = Math.max(...prices);
				const min = Math.min(...prices);
				const range = max - min || 1;

				const points = data.map((d, i) => {
					const x = (i / (data.length - 1)) * 800;
					const y = 160 - ((d.avg_price - min) / range) * 120; // 200px 높이 기준 내부 여백 포함
					return `${x},${y}`;
				});

				const pathData = `M${points.join(' L')}`;
				document.getElementById('modal-chart-path').setAttribute('d', pathData);
				document.getElementById('modal-chart-area').setAttribute('d', `${pathData} L800,200 L0,200 Z`);
			}

			closeModal?.addEventListener('click', () => modal.close());
			
			// 다이얼로그 바깥 클릭 시 닫기
			modal?.addEventListener('click', (e) => {
				if (e.target === modal) modal.close();
			});

			// 문서 로드 후 실행
			initDistricts();
		</script>

		<!-- 페이지 조회수 카운터 스크립트 -->
		<script is:inline>
			async function initViewCount() {
				const namespace = 'estateintel-blog-views';
				// URL의 pathname을 안전한 키로 변환 (예: blog_2026-05-17-market-briefing_)
				let key = window.location.pathname.replace(/\//g, '_');
				if (key.length === 0 || key === '_') key = 'home';
				
				try {
					// 페이지 로드 시 1 증가시키고 현재 값을 가져옴
					const res = await fetch(`https://api.counterapi.dev/v1/${namespace}/${key}/up`);
					const data = await res.json();
					const viewsElement = document.getElementById('page-views');
					if (viewsElement && data.count) {
						viewsElement.innerText = data.count.toLocaleString();
					}
				} catch (e) {
					console.error('Failed to update view count:', e);
					const viewsElement = document.getElementById('page-views');
					if (viewsElement) {
						viewsElement.innerText = '-';
					}
				}
			}
			
			// 문서가 로드되면 조회수 카운트 실행
			initViewCount();
		</script>

		<Footer />
	</body>
</html>
