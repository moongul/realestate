---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1280px;
				margin: 0 auto;
				padding: 48px 80px;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 40px 24px;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
			}
			ul li a {
				display: block;
				text-decoration: none;
				color: var(--ink);
			}
			ul li img {
				display: block; 
				width: 100%;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				border-radius: var(--rounded-md);
				margin-bottom: 12px;
				transition: transform 0.2s ease;
			}
			ul li a:hover img {
				box-shadow: var(--shadow-airbnb);
			}
			.content-wrap {
				display: flex;
				flex-direction: column;
				gap: 2px;
			}
			.meta-row {
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.category-badge {
				font-size: 11px;
				font-weight: 600;
				padding: 2px 8px;
				border-radius: var(--rounded-full);
				background: var(--surface-strong);
				color: var(--muted);
				text-transform: uppercase;
			}
			.category-badge.analysis {
				background: #eef2ff;
				color: #4338ca;
			}
			.category-badge.market {
				background: #fff1f2;
				color: #e11d48;
			}
			.title {
				margin: 0;
				color: var(--ink);
				font-size: 16px;
				font-weight: 600;
				line-height: 1.25;
			}
			.date {
				margin: 0;
				color: var(--muted);
				font-size: 14px;
				line-height: 1.43;
			}
			@media (max-width: 720px) {
				main {
					padding: 32px 24px;
				}
				ul {
					grid-template-columns: 1fr;
				}
			}

			/* Filter Styles */
			.filter-container {
				display: flex;
				gap: 12px;
				margin-bottom: 32px;
				justify-content: center;
			}
			.filter-btn {
				background: var(--surface-soft);
				border: 1px solid var(--hairline);
				padding: 10px 20px;
				border-radius: var(--rounded-full);
				cursor: pointer;
				font-size: 14px;
				font-weight: 500;
				color: var(--muted);
				transition: all 0.2s;
			}
			.filter-btn:hover {
				background: var(--surface-strong);
				color: var(--ink);
			}
			.filter-btn.active {
				background: var(--ink);
				color: var(--canvas);
				border-color: var(--ink);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="filter-container">
					<button class="filter-btn active" data-category="all">전체</button>
					<button class="filter-btn" data-category="analysis">분석 리포트</button>
					<button class="filter-btn" data-category="market">시세 브리핑</button>
				</div>
				<ul id="post-list">
					{
						posts.map((post) => (
							<li class="post-item" data-category={post.data.category}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && <img src={post.data.heroImage} alt="" />}
									<div class="content-wrap">
										<div class="meta-row">
											<p class="date">
												<FormattedDate date={post.data.pubDate} />
											</p>
											<span class={`category-badge ${post.data.category}`}>
												{post.data.category === 'analysis' ? '리포트' : '시세 브리핑'}
											</span>
										</div>
										<h4 class="title">{post.data.title}</h4>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<script is:inline>
			const filterBtns = document.querySelectorAll('.filter-btn');
			const postItems = document.querySelectorAll('.post-item');

			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					// Update buttons
					filterBtns.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');

					const category = btn.getAttribute('data-category');

					// Filter items
					postItems.forEach(item => {
						if (category === 'all' || item.getAttribute('data-category') === category) {
							item.style.display = 'block';
						} else {
							item.style.display = 'none';
						}
					});
				});
			});
		</script>
		<Footer />
	</body>
</html>
