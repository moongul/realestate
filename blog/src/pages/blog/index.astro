---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`인사이트 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1280px;
				margin: 0 auto;
				padding: 64px 24px;
			}
			.page-header {
				margin-bottom: 64px;
				text-align: center;
			}
			.page-header h1 {
				font-size: 48px;
				margin-bottom: 16px;
			}
			.page-header p {
				font-size: 18px;
				color: var(--muted);
			}

			/* Filter Styles */
			.filter-container {
				display: flex;
				gap: 8px;
				margin-bottom: 48px;
				justify-content: center;
			}
			.filter-btn {
				background: var(--surface-variant);
				border: 1px solid var(--outline-variant);
				padding: 8px 20px;
				border-radius: var(--rounded-sm);
				cursor: pointer;
				font-size: 14px;
				font-weight: 600;
				color: var(--body);
				transition: all 0.2s;
			}
			.filter-btn:hover {
				background: #eee;
			}
			.filter-btn.active {
				background: var(--primary);
				color: white;
				border-color: var(--primary);
			}

			/* Post Grid */
			ul {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
				gap: 40px;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.post-item {
				height: 100%;
			}
			.post-card {
				display: flex;
				flex-direction: column;
				background: white;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-md);
				height: 100%;
				overflow: hidden;
				box-shadow: var(--shadow-sm);
				transition: all 0.3s ease;
				text-decoration: none;
			}
			.post-card:hover {
				transform: translateY(-8px);
				box-shadow: var(--shadow-md);
				border-color: var(--secondary);
			}
			
			.card-content {
				padding: 32px;
				display: flex;
				flex-direction: column;
				flex: 1;
			}
			.meta-row {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-bottom: 16px;
			}
			.category-badge {
				font-size: 11px;
				font-weight: 800;
				padding: 4px 10px;
				border-radius: 2px;
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}
			.category-badge.analysis {
				background: #eef2ff;
				color: #4338ca;
			}
			.category-badge.market {
				background: #fff1f2;
				color: #e11d48;
			}
			.date {
				font-size: 13px;
				color: var(--muted);
				font-weight: 500;
			}
			.title {
				margin: 0 0 16px 0;
				color: var(--primary);
				font-size: 22px;
				font-weight: 700;
				line-height: 1.3;
			}
			.description {
				margin: 0;
				color: var(--body);
				font-size: 15px;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
				margin-bottom: 24px;
			}
			.read-more {
				margin-top: auto;
				padding-top: 24px;
				border-top: 1px solid var(--outline-variant);
				display: flex;
				align-items: center;
				gap: 4px;
				font-size: 14px;
				font-weight: 700;
				color: var(--secondary);
			}

			@media (max-width: 720px) {
				.page-header h1 { font-size: 32px; }
				ul { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>부동산 인사이트</h1>
				<p>심층 시장 분석 리포트 및 일일 시세 브리핑</p>
			</section>

			<section>
				<div class="filter-container">
					<button class="filter-btn active" data-category="all">전체</button>
					<button class="filter-btn" data-category="analysis">분석 리포트</button>
					<button class="filter-btn" data-category="market">시세 브리핑</button>
				</div>
				<ul id="post-list">
					{
						posts.map((post) => (
							<li class="post-item" data-category={post.data.category}>
								<a href={`/blog/${post.id}/`} class="post-card">
									<div class="card-content">
										<div class="meta-row">
											<span class={`category-badge ${post.data.category}`}>
												{post.data.category === 'analysis' ? '리포트' : '시세'}
											</span>
											<p class="date">
												<FormattedDate date={post.data.pubDate} />
											</p>
										</div>
										<h4 class="title">{post.data.title}</h4>
										<p class="description">{post.data.description}</p>
										<div class="read-more">
											리포트 상세보기 <span class="material-symbols-outlined" style="font-size: 18px;">arrow_forward</span>
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<script is:inline>
			const filterBtns = document.querySelectorAll('.filter-btn');
			const postItems = document.querySelectorAll('.post-item');

			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					// Update buttons
					filterBtns.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');

					const category = btn.getAttribute('data-category');

					// Filter items
					postItems.forEach(item => {
						if (category === 'all' || item.getAttribute('data-category') === category) {
							item.style.display = 'block';
						} else {
							item.style.display = 'none';
						}
					});
				});
			});
		</script>
		<Footer />
	</body>
</html>
