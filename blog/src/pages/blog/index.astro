---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort((a, b) => {
	const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	if (dateDiff !== 0) return dateDiff;
	return b.id.localeCompare(a.id);
});
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`인사이트 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1280px;
				margin: 0 auto;
				padding: 64px 24px;
			}
			.page-header {
				margin-bottom: 64px;
				text-align: center;
			}
			.page-header h1 {
				font-size: 48px;
				margin-bottom: 16px;
			}
			.page-header p {
				font-size: 18px;
				color: var(--muted);
			}

			/* Filter Styles */
			.filter-container {
				display: flex;
				gap: 8px;
				margin-bottom: 48px;
				justify-content: center;
			}
			.filter-btn {
				background: var(--surface-variant);
				border: 1px solid var(--outline-variant);
				padding: 8px 20px;
				border-radius: var(--rounded-sm);
				cursor: pointer;
				font-size: 14px;
				font-weight: 600;
				color: var(--body);
				transition: all 0.2s;
			}
			.filter-btn:hover {
				background: #eee;
			}
			.filter-btn.active {
				background: var(--primary);
				color: white;
				border-color: var(--primary);
			}

			/* Post List - Compact Institutional Style */
			ul {
				display: flex;
				flex-direction: column;
				list-style-type: none;
				margin: 0;
				padding: 0;
				border-top: 3px solid var(--primary); /* 두께 미세 조정으로 업데이트 유도 */
			}
			.post-item {
				width: 100%;
			}
			.post-card {
				display: flex;
				flex-direction: row;
				align-items: center;
				background: #ffffff;
				border-bottom: 1px solid var(--outline-variant);
				padding: 28px 20px; /* 패딩 미세 조정 */
				transition: all 0.2s ease;
				text-decoration: none;
				gap: 40px;
			}
			.post-card:hover {
				background: #f1f4f6;
				padding-left: 20px;
			}
			
			.date-meta {
				flex-shrink: 0;
				width: 120px;
				display: flex;
				flex-direction: column;
				gap: 8px;
			}
			.date {
				font-size: 13px;
				color: var(--muted);
				font-weight: 500;
			}
			.category-badge {
				font-size: 10px;
				font-weight: 800;
				padding: 3px 8px;
				border-radius: 2px;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				width: fit-content;
			}
			.category-badge.analysis {
				background: #eef2ff;
				color: #4338ca;
			}
			.category-badge.market {
				background: #fff1f2;
				color: #e11d48;
			}

			.card-content {
				display: flex;
				flex-direction: column;
				flex: 1;
				gap: 8px;
			}
			.title {
				margin: 0;
				color: var(--primary);
				font-size: 19px;
				font-weight: 700;
				line-height: 1.4;
			}
			.description {
				margin: 0;
				color: var(--body);
				font-size: 15px;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 1;
				-webkit-box-orient: vertical;
				overflow: hidden;
				opacity: 0.8;
			}
			.view-action {
				color: var(--secondary);
				font-weight: 700;
				font-size: 13px;
				display: flex;
				align-items: center;
				gap: 4px;
				opacity: 0;
				transition: opacity 0.2s;
			}
			.post-card:hover .view-action {
				opacity: 1;
			}

			@media (max-width: 720px) {
				.post-card {
					flex-direction: column;
					align-items: flex-start;
					gap: 12px;
					padding: 24px 0;
				}
				.date-meta {
					flex-direction: row;
					width: 100%;
					align-items: center;
					justify-content: space-between;
				}
				.title { font-size: 17px; }
				.view-action { display: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>부동산 인사이트</h1>
				<p>심층 시장 분석 리포트 및 일일 시세 브리핑</p>
			</section>

			<section>
				<div class="filter-container">
					<button class="filter-btn active" data-category="all">전체</button>
					<button class="filter-btn" data-category="analysis">분석 리포트</button>
					<button class="filter-btn" data-category="market">시세 브리핑</button>
				</div>
				<ul id="post-list">
					{
						posts.map((post) => (
							<li class="post-item" data-category={post.data.category}>
								<a href={`/blog/${post.id}/`} class="post-card">
									<div class="date-meta">
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<span class={`category-badge ${post.data.category}`}>
											{post.data.category === 'analysis' ? '리포트' : '시세'}
										</span>
									</div>
									<div class="card-content">
										<h4 class="title">{post.data.title}</h4>
										<p class="description">{post.data.description}</p>
									</div>
									<div class="view-action">
										리포트 보기 <span class="material-symbols-outlined" style="font-size: 16px;">arrow_forward</span>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<script is:inline>
			const filterBtns = document.querySelectorAll('.filter-btn');
			const postItems = document.querySelectorAll('.post-item');

			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					filterBtns.forEach(b => b.classList.remove('active'));
					btn.classList.add('active');

					const category = btn.getAttribute('data-category');

					postItems.forEach(item => {
						if (category === 'all' || item.getAttribute('data-category') === category) {
							item.style.display = 'block';
						} else {
							item.style.display = 'none';
						}
					});
				});
			});
		</script>
		<Footer />
	</body>
</html>
