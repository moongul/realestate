---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import latestStats from '../data/latest_stats.json';

const topGainer = latestStats.top_gainers[0] || { district_name: 'N/A', prev_diff_rate: 0 };
const avgPrice = latestStats.avg_seoul_price.toLocaleString();
const totalTrades = latestStats.total_trades;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero-section">
				<div class="hero-overlay"></div>
				<div class="container hero-container">
					<div class="hero-content">
						<span class="badge">Institutional Grade Analysis</span>
						<h1>Data-Driven Real Estate Insights</h1>
						<p class="subtitle">
							Unlocking institutional-quality market data and predictive analytics for professional real estate investors. Navigate complex global markets with vetted research.
						</p>
						<div class="hero-actions">
							<a href="/blog" class="btn-primary">
								Latest Reports
								<span class="material-symbols-outlined">arrow_forward</span>
							</a>
							<a href="/about" class="btn-outline">Our Methodology</a>
						</div>
					</div>
					<div class="hero-image">
						<img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1200&h=800&auto=format&fit=crop" alt="Modern Architecture" />
					</div>
				</div>
			</section>

			<!-- Market Trends Section -->
			<section class="trends-section">
				<div class="container">
					<div class="section-header">
						<div class="header-text">
							<h2>Market Trends</h2>
							<p>{latestStats.last_updated} Seoul Performance Indicators</p>
						</div>
						<a href="/blog" class="dashboard-link">
							View Daily Briefings <span class="material-symbols-outlined">trending_up</span>
						</a>
					</div>
					
					<div class="bento-grid">
						<!-- Large Chart Card -->
						<div class="bento-card large chart-card">
							<div class="card-header">
								<h3>Seoul Price Index</h3>
								<div class="trend-badge">
									{topGainer.prev_diff_rate > 0 ? '+' : ''}{topGainer.prev_diff_rate.toFixed(2)}% Momentum in {topGainer.district_name}
								</div>
							</div>
							<div class="chart-container">
								<svg viewBox="0 0 800 250" class="chart-svg">
									<path d="M0,200 Q150,180 250,150 T500,80 T800,20" fill="none" stroke="var(--secondary)" stroke-width="3" />
									<path d="M0,200 Q150,180 250,150 T500,80 T800,20 L800,250 L0,250 Z" fill="var(--secondary)" opacity="0.05" />
								</svg>
							</div>
							<div class="stat-footer">
								<div class="stat-item">
									<span class="label">Avg Seoul Price</span>
									<span class="value">₩{avgPrice}만</span>
								</div>
								<div class="stat-item">
									<span class="label">Top Gainer</span>
									<span class="value">{topGainer.district_name}</span>
								</div>
								<div class="stat-item">
									<span class="label">Market Volume</span>
									<span class="value">{totalTrades} Trades</span>
								</div>
							</div>
						</div>

						<!-- Regional Liquidity Card -->
						<div class="bento-card medium dark-card">
							<div class="card-content">
								<span class="material-symbols-outlined large-icon">location_city</span>
								<h3>Market Liquidity</h3>
								<p>
									As of {latestStats.last_updated}, we observed {totalTrades} verified transactions across 25 districts. 
									The market is showing a {topGainer.prev_diff_rate > 0 ? 'bullish' : 'stable'} trend led by {topGainer.district_name}.
								</p>
							</div>
							<div class="card-footer">
								<div class="status-indicator">
									<span class="material-symbols-outlined">check_circle</span>
									<span>Real-time Data Synced</span>
								</div>
							</div>
						</div>

						<!-- Capital Allocation Card -->
						<div class="bento-card small">
							<h4 class="label-md">District Performance</h4>
							<div class="allocation-stack">
								{latestStats.top_gainers.slice(0, 3).map((d) => (
									<div class="allocation-item">
										<div class="alloc-label">{d.district_name} (+{d.prev_diff_rate.toFixed(1)}%)</div>
										<div class="progress-bar"><div class="progress" style={`width: ${Math.min(100, d.prev_diff_rate * 10 + 50)}%`}></div></div>
									</div>
								))}
							</div>
						</div>

						<!-- Analyst Insight Card -->
						<div class="bento-card wide insight-card">
							<div class="insight-image">
								<img src="https://images.unsplash.com/photo-1454165833767-027ffea70288?q=80&w=400&h=400&auto=format&fit=crop" alt="Analyst" />
							</div>
							<div class="insight-content">
								<h3>Data-Driven Insights</h3>
								<p>
									Our AI-driven analysis monitors official MOLIT data to detect shifts in regional demand. 
									The current focus is on {topGainer.district_name} and other Tier 1 districts showing high liquidity.
								</p>
								<a href="/blog" class="pro-link">Explore Detailed Reports →</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Newsletter Section -->
			<section class="newsletter-section">
				<div class="container narrow">
					<h2>Get the Intelligence.</h2>
					<p>Join 50,000+ institutional investors who receive our weekly deep-dive on market movements and regulatory shifts.</p>
					<div class="form-container">
						<input type="email" placeholder="professional@company.com" />
						<button class="btn-primary">Subscribe</button>
					</div>
					<p class="disclaimer">We respect your privacy. Professional data only.</p>
				</div>
			</section>
		</main>
		<Footer />

		<style>
			/* Container */
			.container {
				max-width: 1280px;
				margin: 0 auto;
				padding: 0 24px;
			}

			/* Hero Section */
			.hero-section {
				background: var(--primary-container);
				position: relative;
				padding: 96px 0;
				overflow: hidden;
				color: var(--on-primary);
			}
			.hero-overlay {
				position: absolute;
				inset: 0;
				opacity: 0.1;
				background-image: radial-gradient(circle at 2px 2px, #8192a7 1px, transparent 0);
				background-size: 40px 40px;
				pointer-events: none;
			}
			.hero-container {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 64px;
				align-items: center;
				position: relative;
				z-index: 10;
			}
			.badge {
				display: inline-block;
				background: var(--secondary-container);
				color: var(--primary);
				padding: 4px 12px;
				border-radius: var(--rounded-sm);
				font-size: 12px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 24px;
			}
			.hero-content h1 {
				font-size: 56px;
				line-height: 1.1;
				margin-bottom: 24px;
				color: white;
			}
			.subtitle {
				font-size: 20px;
				line-height: 1.5;
				color: rgba(255, 255, 255, 0.8);
				margin-bottom: 48px;
				max-width: 560px;
			}
			.hero-actions {
				display: flex;
				gap: 16px;
				flex-wrap: wrap;
			}
			.btn-primary {
				background: var(--secondary);
				color: white;
				padding: 12px 24px;
				border-radius: var(--rounded-sm);
				font-weight: 600;
				display: flex;
				align-items: center;
				gap: 8px;
				transition: opacity 0.2s;
				text-decoration: none;
			}
			.btn-primary:hover {
				opacity: 0.9;
			}
			.btn-outline {
				border: 1px solid rgba(255, 255, 255, 0.3);
				color: white;
				padding: 12px 24px;
				border-radius: var(--rounded-sm);
				font-weight: 600;
				text-decoration: none;
			}
			.btn-outline:hover {
				background: rgba(255, 255, 255, 0.05);
			}
			.hero-image img {
				width: 100%;
				height: 500px;
				object-fit: cover;
				border-radius: var(--rounded-lg);
				box-shadow: var(--shadow-md);
				border: 1px solid rgba(255, 255, 255, 0.1);
			}

			/* Trends Section */
			.trends-section {
				padding: 96px 0;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				margin-bottom: 40px;
			}
			.header-text h2 {
				font-size: 32px;
				margin-bottom: 8px;
			}
			.header-text p {
				color: var(--muted);
			}
			.dashboard-link {
				display: flex;
				align-items: center;
				gap: 4px;
				color: var(--secondary);
				font-weight: 600;
				font-size: 14px;
				text-decoration: none;
			}

			/* Bento Grid */
			.bento-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 24px;
			}
			.bento-card {
				background: white;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-lg);
				padding: 32px;
				box-shadow: var(--shadow-sm);
			}
			.bento-card.large { grid-column: span 8; }
			.bento-card.medium { grid-column: span 4; }
			.bento-card.small { grid-column: span 4; }
			.bento-card.wide { grid-column: span 8; }

			.chart-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 24px;
			}
			.trend-badge {
				background: rgba(0, 166, 86, 0.1);
				color: var(--tertiary);
				padding: 4px 8px;
				border-radius: 4px;
				font-size: 12px;
				font-weight: 700;
			}
			.chart-container {
				height: 200px;
				margin-bottom: 24px;
			}
			.stat-footer {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				padding-top: 24px;
				border-top: 1px solid var(--outline-variant);
			}
			.stat-item .label {
				font-size: 11px;
				text-transform: uppercase;
				color: var(--muted);
				font-weight: 700;
				display: block;
				margin-bottom: 4px;
			}
			.stat-item .value {
				font-size: 20px;
				font-weight: 700;
				color: var(--primary);
			}

			.dark-card {
				background: var(--primary);
				color: white;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}
			.dark-card h3 { color: white; }
			.large-icon {
				font-size: 48px;
				color: var(--secondary-container);
				margin-bottom: 24px;
			}
			.status-indicator {
				display: flex;
				align-items: center;
				gap: 8px;
				color: var(--tertiary);
				font-weight: 600;
				font-size: 14px;
			}

			.allocation-stack {
				margin-top: 24px;
				display: flex;
				flex-direction: column;
				gap: 20px;
			}
			.alloc-label {
				font-size: 13px;
				font-weight: 600;
				margin-bottom: 8px;
				color: var(--body);
			}
			.progress-bar {
				height: 6px;
				background: var(--surface-variant);
				border-radius: var(--rounded-full);
				overflow: hidden;
			}
			.progress {
				height: 100%;
				background: var(--secondary);
			}

			.insight-card {
				display: flex;
				align-items: center;
				gap: 32px;
				background: var(--surface-variant);
			}
			.insight-image img {
				width: 100px;
				height: 100px;
				border-radius: 50%;
				object-fit: cover;
				border: 3px solid white;
			}
			.pro-link {
				display: inline-block;
				margin-top: 16px;
				font-weight: 700;
				color: var(--secondary);
				text-decoration: none;
			}

			/* Newsletter Section */
			.newsletter-section {
				background: var(--primary);
				color: white;
				padding: 80px 0;
				text-align: center;
			}
			.newsletter-section h2 { color: white; font-size: 36px; margin-bottom: 16px; }
			.newsletter-section p { color: rgba(255, 255, 255, 0.7); font-size: 18px; margin-bottom: 40px; }
			.form-container {
				display: flex;
				gap: 12px;
				justify-content: center;
				margin-bottom: 16px;
			}
			.form-container input {
				flex: 1;
				max-width: 400px;
				padding: 14px 20px;
				border: none;
				border-radius: var(--rounded-sm);
				font-size: 16px;
			}
			.form-container button {
				background: var(--secondary);
				color: white;
				border: none;
				padding: 0 32px;
				border-radius: var(--rounded-sm);
				font-weight: 700;
				cursor: pointer;
			}
			.disclaimer {
				font-size: 12px;
				color: rgba(255, 255, 255, 0.5);
			}

			@media (max-width: 1024px) {
				.hero-container { grid-template-columns: 1fr; }
				.hero-image { display: none; }
				.bento-card.large, .bento-card.medium, .bento-card.small, .bento-card.wide { grid-column: span 12; }
			}
			@media (max-width: 640px) {
				.form-container { flex-direction: column; align-items: stretch; }
				.form-container input { max-width: none; }
			}
		</style>
	</body>
</html>
