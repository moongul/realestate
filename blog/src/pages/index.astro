---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero">
				<div class="hero-content">
					<span class="badge">Institutional Grade Analysis</span>
					<h1>Data-Driven Real Estate Insights</h1>
					<p class="subtitle">
						Unlocking institutional-quality market data and predictive analytics for professional real estate investors. Navigate complex global markets with vetted research.
					</p>
					<div class="hero-actions">
						<a href="/blog" class="btn-primary">
							Latest Reports
							<span class="material-symbols-outlined">arrow_forward</span>
						</a>
						<a href="/about" class="btn-secondary">Our Methodology</a>
					</div>
				</div>
				<div class="hero-image">
					<img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1200&h=800&auto=format&fit=crop" alt="Modern Architecture" />
				</div>
			</section>

			<!-- Bento Features Section -->
			<section class="features">
				<div class="section-header">
					<h2>Market Trends</h2>
					<p>Performance Indicators & AI Insights</p>
				</div>
				
				<div class="bento-grid">
					<div class="bento-item large">
						<div class="bento-header">
							<h3>Yield Compression Trends</h3>
							<span class="trend-tag">+1.2% Momentum</span>
						</div>
						<div class="mock-chart">
							<svg viewBox="0 0 800 200">
								<path d="M0,150 Q150,130 250,100 T500,50 T800,20" fill="none" stroke="var(--secondary)" stroke-width="3" />
							</svg>
						</div>
						<div class="stat-grid">
							<div class="stat-item">
								<span class="label">Industrial</span>
								<span class="value">4.2%</span>
							</div>
							<div class="stat-item">
								<span class="label">Multifamily</span>
								<span class="value">3.8%</span>
							</div>
							<div class="stat-item">
								<span class="label">Office</span>
								<span class="value">5.4%</span>
							</div>
						</div>
					</div>
					
					<div class="bento-item dark">
						<span class="material-symbols-outlined icon">location_city</span>
						<h3>Regional Liquidity</h3>
						<p>Seoul markets show resilient liquidity despite interest rate fluctuations in major hubs.</p>
						<div class="status">
							<span class="material-symbols-outlined">check_circle</span>
							<span>Tier 1 Districts Stable</span>
						</div>
					</div>

					<div class="bento-item high">
						<img src="https://images.unsplash.com/photo-1454165833767-027ffea70288?q=80&w=400&h=400&auto=format&fit=crop" alt="Analyst" />
						<div class="item-content">
							<h3>Analyst Insight</h3>
							<p>Macroeconomic pressures are shifting the risk-reward profile.</p>
							<a href="/blog">Read Q4 Forecast →</a>
						</div>
					</div>
				</div>
			</section>
		</main>

		<style>
			/* Hero Section */
			.hero {
				background: var(--primary-container);
				padding: 96px 24px;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 64px;
				align-items: center;
				max-width: 1280px;
				margin: 0 auto;
				border-radius: 0 0 var(--rounded-lg) var(--rounded-lg);
				position: relative;
				overflow: hidden;
			}
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				opacity: 0.05;
				background-image: radial-gradient(circle at 2px 2px, #ffffff 1px, transparent 0);
				background-size: 40px 40px;
			}
			.hero-content {
				position: relative;
				z-index: 10;
			}
			.badge {
				display: inline-block;
				background: var(--secondary-container);
				color: var(--primary);
				padding: 4px 12px;
				border-radius: var(--rounded-sm);
				font-size: 12px;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 24px;
			}
			.hero h1 {
				font-size: 56px;
				color: white;
				margin-bottom: 24px;
				line-height: 1.1;
			}
			.subtitle {
				font-size: 20px;
				color: rgba(255, 255, 255, 0.7);
				line-height: 1.5;
				margin-bottom: 48px;
				max-width: 560px;
			}
			.hero-actions {
				display: flex;
				gap: 16px;
			}
			.btn-primary {
				background: var(--secondary);
				color: white;
				padding: 14px 28px;
				border-radius: var(--rounded-sm);
				font-weight: 600;
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.btn-secondary {
				border: 1px solid rgba(255, 255, 255, 0.3);
				color: white;
				padding: 14px 28px;
				border-radius: var(--rounded-sm);
				font-weight: 600;
			}
			.hero-image img {
				width: 100%;
				height: 500px;
				object-fit: cover;
				border-radius: var(--rounded-lg);
				box-shadow: var(--shadow-md);
				border: 1px solid rgba(255, 255, 255, 0.1);
			}

			/* Features Bento Grid */
			.features {
				max-width: 1280px;
				margin: 96px auto;
				padding: 0 24px;
			}
			.section-header {
				margin-bottom: 48px;
			}
			.section-header h2 {
				font-size: 32px;
				margin-bottom: 8px;
			}
			.section-header p {
				color: var(--muted);
				font-weight: 500;
			}

			.bento-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 24px;
			}
			.bento-item {
				background: white;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-lg);
				padding: 32px;
				box-shadow: var(--shadow-sm);
			}
			.bento-item.large {
				grid-column: span 8;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}
			.bento-item.dark {
				grid-column: span 4;
				background: var(--primary);
				color: white;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 24px;
			}
			.bento-item.dark h3 { color: white; }
			.bento-item.dark .icon { font-size: 48px; color: var(--secondary-container); }
			.bento-item.dark .status { 
				display: flex; 
				align-items: center; 
				gap: 8px; 
				color: var(--tertiary);
				font-weight: 600;
				font-size: 14px;
			}

			.bento-item.high {
				grid-column: span 12;
				display: flex;
				align-items: center;
				gap: 32px;
				background: var(--surface-variant);
			}
			.bento-item.high img {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				object-fit: cover;
				border: 4px solid white;
			}

			.bento-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 32px;
			}
			.trend-tag {
				background: rgba(0, 166, 86, 0.1);
				color: var(--tertiary);
				padding: 4px 8px;
				border-radius: 4px;
				font-size: 12px;
				font-weight: 700;
			}
			.stat-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
				padding-top: 24px;
				border-top: 1px solid var(--outline-variant);
			}
			.stat-item .label {
				font-size: 12px;
				text-transform: uppercase;
				color: var(--muted);
				font-weight: 600;
				display: block;
				margin-bottom: 4px;
			}
			.stat-item .value {
				font-size: 24px;
				font-weight: 700;
				color: var(--primary);
			}

			@media (max-width: 1024px) {
				.hero { grid-template-columns: 1fr; }
				.hero-image { display: none; }
				.bento-item.large, .bento-item.dark { grid-column: span 12; }
			}
		</style>
		<Footer />
	</body>
</html>
