---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import latestStats from '../data/latest_stats.json';

const topGainer = latestStats.top_gainers[0] || { district_name: 'N/A', prev_diff_rate: 0 };
const avgPriceEok = (latestStats.avg_seoul_price / 10000).toFixed(2);
const totalTrades = latestStats.total_trades;

// SVG 차트 경로 생성 로직 (실제 데이터를 좌표로 변환)
const history = latestStats.history || [];
const maxPrice = Math.max(...history.map(h => h.price), 1);
const minPrice = Math.min(...history.map(h => h.price), 0);
const priceRange = maxPrice - minPrice || 1;

// 800x200 좌표계로 변환
const points = history.map((h, i) => {
	const x = (i / (history.length - 1)) * 800;
	const y = 200 - ((h.price - minPrice) / priceRange) * 150 - 25; // 25px 여백
	return `${x},${y}`;
});
const chartPath = history.length > 1 ? `M${points.join(' L')}` : "M0,200 L800,200";
const areaPath = `${chartPath} L800,250 L0,250 Z`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero-section">
				<div class="hero-overlay"></div>
				<div class="container hero-container">
					<div class="hero-content">
						<span class="badge">기관급 전문 분석 리포트</span>
						<h1>데이터 기반의<br />부동산 인사이트</h1>
						<p class="subtitle">
							전문 투자자를 위한 고품질 시장 데이터와 인공지능 기반의 예측 분석을 제공합니다. 검증된 연구 데이터를 통해 복잡한 시장의 흐름을 정확히 파악하세요.
						</p>
						<div class="hero-actions">
							<a href="/blog" class="btn-primary">
								최신 리포트 읽기
								<span class="material-symbols-outlined">arrow_forward</span>
							</a>
							<a href="/about" class="btn-outline">분석 방법론</a>
						</div>
					</div>
					<div class="hero-image">
						<img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1200&h=800&auto=format&fit=crop" alt="현대적인 건축물" />
					</div>
				</div>
			</section>

			<!-- Market Trends Section -->
			<section class="trends-section">
				<div class="container">
					<div class="section-header">
						<div class="header-text">
							<h2>시장 동향</h2>
							<p>{latestStats.last_updated} 서울 부동산 주요 지표</p>
						</div>
						<a href="/blog" class="dashboard-link">
							일일 시세 브리핑 보기 <span class="material-symbols-outlined">trending_up</span>
						</a>
					</div>
					
					<div class="bento-grid">
						<!-- Large Chart Card -->
						<div class="bento-card large chart-card">
							<div class="card-header">
								<h3>서울 아파트 시세 지수</h3>
								<div class="trend-badge">
									{topGainer.district_name} {topGainer.prev_diff_rate > 0 ? '+' : ''}{topGainer.prev_diff_rate.toFixed(2)}% 상승 모멘텀
								</div>
							</div>
							<div class="chart-container">
								<svg viewBox="0 0 800 250" class="chart-svg" preserveAspectRatio="none">
									<path d={chartPath} fill="none" stroke="var(--secondary)" stroke-width="3" stroke-linejoin="round" stroke-linecap="round" />
									<path d={areaPath} fill="var(--secondary)" opacity="0.05" />
								</svg>
								<div class="chart-label">최근 15일 서울 평균 시세 추이</div>
							</div>
							<div class="stat-footer">
								<div class="stat-item">
									<span class="label">서울 평균 매매가</span>
									<span class="value">{avgPriceEok}억</span>
								</div>
								<div class="stat-item">
									<span class="label">최고 상승 지역</span>
									<span class="value">{topGainer.district_name}</span>
								</div>
								<div class="stat-item">
									<span class="label">시장 거래량</span>
									<span class="value">{totalTrades}건</span>
								</div>
							</div>
						</div>

						<!-- Regional Liquidity Card -->
						<div class="bento-card medium dark-card">
							<div class="card-content">
								<span class="material-symbols-outlined large-icon">location_city</span>
								<h3>시장 유동성 분석</h3>
								<p>
									{latestStats.last_updated} 기준, 서울 25개 자치구에서 {totalTrades}건의 검증된 실거래가 포착되었습니다. 
									현재 시장은 {topGainer.district_name}을(를) 중심으로 {topGainer.prev_diff_rate > 0 ? '강세' : '보합'} 흐름을 보이고 있습니다.
								</p>
							</div>
							<div class="card-footer">
								<div class="status-indicator">
									<span class="material-symbols-outlined">check_circle</span>
									<span>실시간 데이터 동기화 완료</span>
								</div>
							</div>
						</div>

						<!-- Capital Allocation Card -->
						<div class="bento-card small">
							<h4 class="label-md">자치구별 시세 등락률</h4>
							<div class="allocation-stack">
								{latestStats.top_gainers.slice(0, 3).map((d) => {
									const maxRate = Math.max(...latestStats.top_gainers.map(g => Math.abs(g.prev_diff_rate)), 0.1);
									const barWidth = Math.max(10, (Math.abs(d.prev_diff_rate) / maxRate) * 100);
									return (
										<div class="allocation-item">
											<div class="alloc-label">{d.district_name} (+{d.prev_diff_rate.toFixed(1)}%)</div>
											<div class="progress-bar"><div class="progress" style={`width: ${barWidth}%`}></div></div>
										</div>
									);
								})}
							</div>
						</div>

						<!-- Analyst Insight Card -->
						<div class="bento-card wide insight-card">
							<div class="insight-image">
								<img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=400&h=400&auto=format&fit=crop" alt="분석가" />
							</div>
							<div class="insight-content">
								<h3>데이터 기반 인사이트</h3>
								<p>
									우리의 AI 에이전트는 국토교통부 실거래 데이터를 실시간 모니터링하여 지역별 수요 변화를 감지합니다. 
									현재 {topGainer.district_name} 및 주요 상급지를 중심으로 유동성 흐름이 집중되고 있습니다.
								</p>
								<a href="/blog" class="pro-link">상세 분석 리포트 탐색하기 →</a>
							</div>
						</div>
					</div>
				</div>
			</section>

		</main>
		<Footer />

		<style>
			/* Container */
			.container {
				max-width: 1280px;
				margin: 0 auto;
				padding: 0 24px;
			}

			/* Hero Section */
			.hero-section {
				background: var(--primary-container);
				position: relative;
				padding: 96px 0;
				overflow: hidden;
				color: var(--on-primary);
			}
			.hero-overlay {
				position: absolute;
				inset: 0;
				opacity: 0.1;
				background-image: radial-gradient(circle at 2px 2px, #8192a7 1px, transparent 0);
				background-size: 40px 40px;
				pointer-events: none;
			}
			.hero-container {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 64px;
				align-items: center;
				position: relative;
				z-index: 10;
			}
			.badge {
				display: inline-block;
				background: var(--secondary-container);
				color: var(--primary);
				padding: 4px 12px;
				border-radius: var(--rounded-sm);
				font-size: 12px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 24px;
			}
			.hero-content h1 {
				font-size: 56px;
				line-height: 1.1;
				margin-bottom: 24px;
				color: white;
			}
			.subtitle {
				font-size: 20px;
				line-height: 1.5;
				color: rgba(255, 255, 255, 0.8);
				margin-bottom: 48px;
				max-width: 560px;
			}
			.hero-actions {
				display: flex;
				gap: 16px;
				flex-wrap: wrap;
			}
			.btn-primary {
				background: var(--secondary);
				color: white;
				padding: 12px 24px;
				border-radius: var(--rounded-sm);
				font-weight: 600;
				display: flex;
				align-items: center;
				gap: 8px;
				transition: opacity 0.2s;
				text-decoration: none;
			}
			.btn-primary:hover {
				opacity: 0.9;
			}
			.btn-outline {
				border: 1px solid rgba(255, 255, 255, 0.3);
				color: white;
				padding: 12px 24px;
				border-radius: var(--rounded-sm);
				font-weight: 600;
				text-decoration: none;
			}
			.btn-outline:hover {
				background: rgba(255, 255, 255, 0.05);
			}
			.hero-image img {
				width: 100%;
				height: 500px;
				object-fit: cover;
				border-radius: var(--rounded-lg);
				box-shadow: var(--shadow-md);
				border: 1px solid rgba(255, 255, 255, 0.1);
			}

			/* Trends Section */
			.trends-section {
				padding: 96px 0;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				margin-bottom: 40px;
			}
			.header-text h2 {
				font-size: 32px;
				margin-bottom: 8px;
			}
			.header-text p {
				color: var(--muted);
			}
			.dashboard-link {
				display: flex;
				align-items: center;
				gap: 4px;
				color: var(--secondary);
				font-weight: 600;
				font-size: 14px;
				text-decoration: none;
			}

			/* Bento Grid */
			.bento-grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 24px;
			}
			.bento-card {
				background: white;
				border: 1px solid var(--outline-variant);
				border-radius: var(--rounded-lg);
				padding: 32px;
				box-shadow: var(--shadow-sm);
			}
			.bento-card.large { grid-column: span 8; }
			.bento-card.medium { grid-column: span 4; }
			.bento-card.small { grid-column: span 4; }
			.bento-card.wide { grid-column: span 8; }

			.chart-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 24px;
			}
			.trend-badge {
				background: rgba(0, 166, 86, 0.1);
				color: var(--tertiary);
				padding: 4px 8px;
				border-radius: 4px;
				font-size: 12px;
				font-weight: 700;
			}
			.chart-container {
				height: 200px;
				margin-bottom: 40px;
				position: relative;
			}
			.chart-svg {
				width: 100%;
				height: 100%;
			}
			.chart-label {
				position: absolute;
				top: -20px;
				right: 0;
				font-size: 11px;
				font-weight: 600;
				color: var(--muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.stat-footer {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				padding-top: 24px;
				border-top: 1px solid var(--outline-variant);
			}
			.stat-item .label {
				font-size: 11px;
				text-transform: uppercase;
				color: var(--muted);
				font-weight: 700;
				display: block;
				margin-bottom: 4px;
			}
			.stat-item .value {
				font-size: 20px;
				font-weight: 700;
				color: var(--primary);
			}

			.dark-card {
				background: var(--primary);
				color: white;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
			}
			.dark-card h3 { color: white; }
			.large-icon {
				font-size: 48px;
				color: var(--secondary-container);
				margin-bottom: 24px;
			}
			.status-indicator {
				display: flex;
				align-items: center;
				gap: 8px;
				color: var(--tertiary);
				font-weight: 600;
				font-size: 14px;
			}

			.allocation-stack {
				margin-top: 24px;
				display: flex;
				flex-direction: column;
				gap: 20px;
			}
			.alloc-label {
				font-size: 13px;
				font-weight: 600;
				margin-bottom: 8px;
				color: var(--body);
			}
			.progress-bar {
				height: 6px;
				background: var(--surface-variant);
				border-radius: var(--rounded-full);
				overflow: hidden;
			}
			.progress {
				height: 100%;
				background: var(--secondary);
			}

			.insight-card {
				display: flex;
				align-items: center;
				gap: 32px;
				background: var(--surface-variant);
			}
			.insight-image img {
				width: 100px;
				height: 100px;
				border-radius: 50%;
				object-fit: cover;
				border: 3px solid white;
			}
			.pro-link {
				display: inline-block;
				margin-top: 16px;
				font-weight: 700;
				color: var(--secondary);
				text-decoration: none;
			}

			@media (max-width: 1024px) {
				.hero-container { grid-template-columns: 1fr; }
				.hero-image { display: none; }
				.bento-card.large, .bento-card.medium, .bento-card.small, .bento-card.wide { grid-column: span 12; }
			}
		</style>
	</body>
</html>
