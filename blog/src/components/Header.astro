---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">인사이트</HeaderLink>
			<HeaderLink href="/about">서비스 소개</HeaderLink>
		</div>
		<div class="actions">
			<div class="search-container">
				<div class="search-box">
					<span class="material-symbols-outlined">&#xe8b6;</span>
					<input type="text" id="search-input" placeholder="검색어를 입력하세요..." autocomplete="off" />
				</div>
				<div id="search-results" class="search-results-dropdown"></div>
			</div>
			<button class="menu-btn material-symbols-outlined">&#xe5d2;</button>
		</div>
	</nav>
</header>

<script is:inline>
	let searchIndex = null;
	const searchInput = document.getElementById('search-input');
	const searchResults = document.getElementById('search-results');

	async function fetchIndex() {
		if (!searchIndex) {
			try {
				const res = await fetch('/search-index.json');
				searchIndex = await res.json();
			} catch (e) {
				console.error('Failed to fetch search index:', e);
				searchIndex = [];
			}
		}
	}

	searchInput?.addEventListener('input', async (e) => {
		const query = e.target.value.toLowerCase().trim();
		if (query.length < 2) {
			searchResults.classList.remove('show');
			return;
		}

		await fetchIndex();
		
		const filtered = searchIndex.filter(post => 
			post.title.toLowerCase().includes(query) || 
			post.description.toLowerCase().includes(query)
		).slice(0, 5);

		if (filtered.length > 0) {
			searchResults.innerHTML = filtered.map(post => `
				<a href="/blog/${post.id}/" class="result-item">
					<div class="result-badge ${post.category}">${post.category === 'market' ? '시세' : '리포트'}</div>
					<div class="result-info">
						<div class="result-title">${post.title}</div>
						<div class="result-date">${new Date(post.pubDate).toLocaleDateString('ko-KR')}</div>
					</div>
				</a>
			`).join('');
			searchResults.classList.add('show');
		} else {
			searchResults.innerHTML = '<div class="no-results">검색 결과가 없습니다.</div>';
			searchResults.classList.add('show');
		}
	});

	document.addEventListener('click', (e) => {
		if (searchInput && searchResults && !searchInput.contains(e.target) && !searchResults.contains(e.target)) {
			searchResults.classList.remove('show');
		}
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		width: 100%;
		height: 64px;
		background: rgba(251, 249, 250, 0.9);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--outline-variant);
		display: flex;
		align-items: center;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--gutter);
	}
	.brand a {
		font-family: 'Pretendard Variable', Pretendard, sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: var(--primary);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 32px;
	}
	.internal-links a {
		padding: 20px 0;
		color: var(--body);
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: all 0.2s;
		font-family: 'Pretendard Variable', Pretendard, sans-serif;
	}
	.internal-links a:hover {
		color: var(--secondary);
	}
	.internal-links a.active {
		color: var(--secondary) !important;
		border-bottom-color: var(--secondary);
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 16px;
	}
	.search-container {
		position: relative;
	}
	.search-box {
		display: flex;
		align-items: center;
		background: var(--surface-variant);
		padding: 10px 16px;
		border-radius: var(--rounded-md);
		gap: 12px;
		border: 1px solid transparent;
		transition: all 0.2s;
	}
	.search-box:focus-within {
		border-color: var(--secondary);
		background: white;
		box-shadow: var(--shadow-sm);
	}
	.search-box input {
		background: transparent;
		border: none;
		outline: none;
		font-size: 13px;
		width: 180px;
		font-family: inherit;
	}
	
	.search-results-dropdown {
		position: absolute;
		top: calc(100% + 8px);
		right: 0;
		width: 420px;
		background-color: #ffffff !important;
		border: 1px solid var(--outline-variant);
		border-radius: var(--rounded-md);
		box-shadow: 0 12px 30px rgba(0,0,0,0.12);
		display: none;
		z-index: 9999;
		max-height: 480px;
		overflow-y: auto;
		padding: 12px; /* 결과창 주변과 글씨간의 패딩 추가 */
	}
	.search-results-dropdown.show {
		display: block;
	}
	.result-item {
		display: flex;
		align-items: flex-start;
		gap: 16px;
		padding: 16px 20px;
		text-decoration: none;
		border-radius: var(--rounded-sm);
		transition: background 0.2s;
		margin-bottom: 4px;
	}
	.result-item:last-child {
		margin-bottom: 0;
	}
	.result-item:hover {
		background: #f1f3f5;
	}
	.result-badge {
		font-size: 10px;
		font-weight: 800;
		padding: 3px 8px;
		border-radius: 4px;
		text-transform: uppercase;
		flex-shrink: 0;
		margin-top: 2px;
	}
	.result-badge.analysis { background: #eef2ff; color: #4338ca; }
	.result-badge.market { background: #fff1f2; color: #e11d48; }
	
	.result-info {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.result-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--primary);
		line-height: 1.4;
	}
	.result-date {
		font-size: 11px;
		color: var(--muted);
	}
	.no-results {
		padding: 24px;
		text-align: center;
		color: var(--muted);
		font-size: 14px;
	}

	.menu-btn {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--primary);
	}
	@media (max-width: 1024px) {
		.internal-links, .search-container {
			display: none;
		}
		.menu-btn {
			display: block;
		}
	}
</style>
