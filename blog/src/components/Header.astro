---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">인사이트</HeaderLink>
			<HeaderLink href="/about">서비스 소개</HeaderLink>
		</div>
		<div class="actions">
			<div class="search-container desktop-search">
				<div class="search-box">
					<span class="material-symbols-outlined">&#xe8b6;</span>
					<input type="text" id="search-input" placeholder="검색어를 입력하세요..." autocomplete="off" />
				</div>
				<div id="search-results" class="search-results-dropdown"></div>
			</div>
			<button class="menu-btn material-symbols-outlined" id="menu-toggle">&#xe5d2;</button>
		</div>
	</nav>
	
	<!-- Mobile Menu Overlay -->
	<div class="mobile-menu" id="mobile-menu">
		<div class="mobile-search-container">
			<div class="search-box">
				<span class="material-symbols-outlined">&#xe8b6;</span>
				<input type="text" id="mobile-search-input" placeholder="검색어를 입력하세요..." autocomplete="off" />
			</div>
			<div id="mobile-search-results" class="search-results-dropdown mobile"></div>
		</div>
		<div class="mobile-links">
			<a href="/">홈</a>
			<a href="/blog">인사이트</a>
			<a href="/about">서비스 소개</a>
		</div>
	</div>
</header>

<script is:inline>
	let searchIndex = null;
	
	// 공통 검색 로직
	async function fetchIndex() {
		if (!searchIndex) {
			try {
				const res = await fetch('/search-index.json');
				searchIndex = await res.json();
			} catch (e) {
				console.error('Failed to fetch search index:', e);
				searchIndex = [];
			}
		}
	}

	function handleSearch(input, results) {
		input?.addEventListener('input', async (e) => {
			const query = e.target.value.toLowerCase().trim();
			if (query.length < 2) {
				results.classList.remove('show');
				return;
			}

			await fetchIndex();
			
			const filtered = searchIndex.filter(post => 
				post.title.toLowerCase().includes(query) || 
				post.description.toLowerCase().includes(query)
			).slice(0, 5);

			if (filtered.length > 0) {
				results.innerHTML = filtered.map(post => `
					<a href="/blog/${post.id}/" class="result-item">
						<div class="result-badge ${post.category}">${post.category === 'market' ? '시세' : '리포트'}</div>
						<div class="result-info">
							<div class="result-title">${post.title}</div>
							<div class="result-date">${new Date(post.pubDate).toLocaleDateString('ko-KR')}</div>
						</div>
					</a>
				`).join('');
				results.classList.add('show');
			} else {
				results.innerHTML = '<div class="no-results">검색 결과가 없습니다.</div>';
				results.classList.add('show');
			}
		});
	}

	// 데스크탑 검색 활성화
	handleSearch(document.getElementById('search-input'), document.getElementById('search-results'));
	// 모바일 검색 활성화
	handleSearch(document.getElementById('mobile-search-input'), document.getElementById('mobile-search-results'));

	// 메뉴 토글 로직
	const menuToggle = document.getElementById('menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');

	menuToggle?.addEventListener('click', () => {
		mobileMenu.classList.toggle('show');
		// 아이콘 변경 (메뉴 <-> 닫기)
		menuToggle.innerHTML = mobileMenu.classList.contains('show') ? '&#xe5cd;' : '&#xe5d2;';
	});

	// 외부 클릭 시 닫기
	document.addEventListener('click', (e) => {
		const searchInput = document.getElementById('search-input');
		const searchResults = document.getElementById('search-results');
		const mobileSearchInput = document.getElementById('mobile-search-input');
		const mobileSearchResults = document.getElementById('mobile-search-results');

		if (searchInput && searchResults && !searchInput.contains(e.target) && !searchResults.contains(e.target)) {
			searchResults.classList.remove('show');
		}
		if (mobileSearchInput && mobileSearchResults && !mobileSearchInput.contains(e.target) && !mobileSearchResults.contains(e.target)) {
			mobileSearchResults.classList.remove('show');
		}
		
		// 메뉴 외부 클릭 시 닫기
		if (mobileMenu && !mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
			mobileMenu.classList.remove('show');
			menuToggle.innerHTML = '&#xe5d2;';
		}
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		width: 100%;
		background: rgba(251, 249, 250, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--outline-variant);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--gutter);
		height: 64px;
	}
	.brand a {
		font-family: 'Pretendard Variable', Pretendard, sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: var(--primary);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 32px;
	}
	.internal-links a {
		padding: 20px 0;
		color: var(--body);
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: all 0.2s;
		font-family: 'Pretendard Variable', Pretendard, sans-serif;
	}
	.internal-links a:hover {
		color: var(--secondary);
	}
	.internal-links a.active {
		color: var(--secondary) !important;
		border-bottom-color: var(--secondary);
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 16px;
	}
	.search-container {
		position: relative;
	}
	.search-box {
		display: flex;
		align-items: center;
		background: var(--surface-variant);
		padding: 10px 16px;
		border-radius: var(--rounded-md);
		gap: 12px;
		border: 1px solid transparent;
		transition: all 0.2s;
	}
	.search-box:focus-within {
		border-color: var(--secondary);
		background: white;
		box-shadow: var(--shadow-sm);
	}
	.search-box input {
		background: transparent;
		border: none;
		outline: none;
		font-size: 13px;
		width: 180px;
		font-family: inherit;
	}
	
	.search-results-dropdown {
		position: absolute;
		top: calc(100% + 8px);
		right: 0;
		width: 420px;
		background-color: #ffffff !important;
		border: 1px solid var(--outline-variant);
		border-radius: var(--rounded-md);
		box-shadow: 0 12px 30px rgba(0,0,0,0.12);
		display: none;
		z-index: 9999;
		max-height: 480px;
		overflow-y: auto;
		padding: 12px;
	}
	.search-results-dropdown.show {
		display: block;
	}
	.result-item {
		display: flex;
		align-items: flex-start;
		gap: 16px;
		padding: 16px 20px;
		text-decoration: none;
		border-radius: var(--rounded-sm);
		transition: background 0.2s;
		margin-bottom: 4px;
	}
	.result-item:last-child {
		margin-bottom: 0;
	}
	.result-item:hover {
		background: #f1f3f5;
	}
	.result-badge {
		font-size: 10px;
		font-weight: 800;
		padding: 3px 8px;
		border-radius: 4px;
		text-transform: uppercase;
		flex-shrink: 0;
		margin-top: 2px;
	}
	.result-badge.analysis { background: #eef2ff; color: #4338ca; }
	.result-badge.market { background: #fff1f2; color: #e11d48; }
	
	.result-info {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.result-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--primary);
		line-height: 1.4;
	}
	.result-date {
		font-size: 11px;
		color: var(--muted);
	}
	.no-results {
		padding: 24px;
		text-align: center;
		color: var(--muted);
		font-size: 14px;
	}

	.menu-btn {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--primary);
		font-size: 28px;
	}

	/* Mobile Menu Styles */
	.mobile-menu {
		display: none;
		position: absolute;
		top: 64px;
		left: 0;
		width: 100%;
		background: white;
		border-bottom: 1px solid var(--outline-variant);
		padding: 24px;
		flex-direction: column;
		gap: 24px;
		box-shadow: 0 10px 20px rgba(0,0,0,0.05);
	}
	.mobile-menu.show {
		display: flex;
	}
	.mobile-links {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.mobile-links a {
		font-size: 18px;
		font-weight: 600;
		color: var(--primary);
		text-decoration: none;
		padding: 8px 0;
	}
	.mobile-search-container {
		width: 100%;
		position: relative;
	}
	.mobile-search-container .search-box {
		width: 100%;
	}
	.mobile-search-container .search-box input {
		width: 100%;
	}
	.search-results-dropdown.mobile {
		width: 100%;
		left: 0;
		right: 0;
		position: static;
		box-shadow: none;
		border: none;
		padding: 12px 0 0 0;
	}

	@media (max-width: 1024px) {
		.internal-links, .desktop-search {
			display: none;
		}
		.menu-btn {
			display: block;
		}
	}
</style>
