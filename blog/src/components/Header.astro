---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">인사이트</HeaderLink>
			<HeaderLink href="/about">서비스 소개</HeaderLink>
		</div>
		<div class="actions">
			<div class="search-box">
				<span class="material-symbols-outlined">search</span>
				<input type="text" placeholder="검색어를 입력하세요..." />
			</div>
			<button class="menu-btn material-symbols-outlined">menu</button>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		width: 100%;
		height: 64px;
		background: rgba(251, 249, 250, 0.9);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--outline-variant);
		display: flex;
		align-items: center;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--gutter);
	}
	.brand a {
		font-family: 'Pretendard Variable', Pretendard, sans-serif;
		font-size: 24px;
		font-weight: 700;
		color: var(--primary);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 32px;
	}
	.internal-links a {
		padding: 20px 0;
		color: var(--body);
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: all 0.2s;
		font-family: 'Pretendard Variable', Pretendard, sans-serif;
	}
	.internal-links a:hover {
		color: var(--secondary);
	}
	.internal-links a.active {
		color: var(--secondary) !important;
		border-bottom-color: var(--secondary);
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 16px;
	}
	.search-box {
		display: flex;
		align-items: center;
		background: var(--surface-variant);
		padding: 6px 12px;
		border-radius: var(--rounded-sm);
		gap: 8px;
	}
	.search-box input {
		background: transparent;
		border: none;
		outline: none;
		font-size: 13px;
		width: 150px;
	}
	.menu-btn {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--primary);
	}
	@media (max-width: 1024px) {
		.internal-links, .search-box {
			display: none;
		}
		.menu-btn {
			display: block;
		}
	}
</style>
